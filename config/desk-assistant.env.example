# DeskAssistant MQTT Client Environment
# Copy to /etc/desk-assistant/env and edit

# Broker (default: localhost)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# Optional: broker authentication
# MQTT_USERNAME=user
# MQTT_PASSWORD=secret

# Pi Zero 2: UART to ESP32 (omit to disable UART bridge)
# UART_DEVICE=/dev/ttyS0
# UART_BAUD=115200
