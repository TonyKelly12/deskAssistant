# DeskAssistant Reporting API - Jetson Orin Nano
# Copy to /etc/desk-assistant/reporting-api.env or source before run

# API server
API_HOST=0.0.0.0
API_PORT=8000

# MQTT broker (localhost when Mosquitto runs on same Jetson)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# Optional: broker auth
# MQTT_USERNAME=
# MQTT_PASSWORD=
